{
  "mcpServers": {
    "sequential-thinking": {
      "command": "/opt/homebrew/bin/npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "serena": {
      "command": "/opt/homebrew/bin/uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--enable-web-dashboard",
        "false"
      ]
    },
    "playwright": {
      "command": "/opt/homebrew/bin/npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    }
  }
}
